NODE_ENV=development
PORT=3333

# JWT — gere um segredo forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_um_segredo_forte_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — origem do frontend
CORS_ORIGIN=http://localhost:5173

# Banco de dados (usado apenas em produção)
# DB_CLIENT=pg
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=corporate
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSL=false
